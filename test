<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Financiero — CHENSIO</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap');

        :root {
            --bg-base: #000000; --bg-card: #111111; --bg-hover: #1a1a1a;
            --border: #222222; --border-light: #333333;
            --text-main: #f5f5f7; --text-muted: #86868b;
            --blue: #0a84ff; --green: #30d158; --amber: #ff9f0a; 
            --red: #ff453a; --purple: #bf5af2; --gray: #8e8e93;
            --font-sans: 'Inter', -apple-system, sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: var(--bg-base); color: var(--text-main); font-family: var(--font-sans); padding: 24px; line-height: 1.5; -webkit-font-smoothing: antialiased; }
        .container { max-width: 1200px; margin: 0 auto; }
        
        /* Nav & Header */
        .header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
        .title-block h1 { font-size: 24px; font-weight: 600; letter-spacing: -0.5px; margin-bottom: 6px; }
        .title-block p { color: var(--text-muted); font-size: 12px; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 1px; }
        
        .nav-tools { display: flex; gap: 8px; }
        .nav-btn { background: transparent; color: var(--text-muted); text-decoration: none; padding: 8px 16px; border-radius: 6px; border: 1px solid var(--border); font-size: 13px; font-weight: 500; transition: all 0.2s; }
        .nav-btn:hover { background: var(--bg-card); color: var(--text-main); border-color: var(--border-light); }

        /* KPIs */
        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 24px; }
        .kpi-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; }
        .kpi-lbl { color: var(--text-muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; font-weight: 600; }
        .kpi-val { font-size: 32px; font-weight: 600; font-family: var(--font-mono); letter-spacing: -1px; }
        
        /* Charts */
        .viz-grid { display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 16px; margin-bottom: 24px; }
        .viz-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; display: flex; flex-direction: column; }
        .viz-card h3 { font-size: 14px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 24px; }
        .canvas-container { position: relative; flex-grow: 1; min-height: 240px; width: 100%; }

        /* Table */
        .table-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th { background: transparent; padding: 16px 24px; font-size: 11px; text-transform: uppercase; color: var(--text-muted); border-bottom: 1px solid var(--border); font-weight: 600; letter-spacing: 0.5px; }
        td { padding: 20px 24px; border-bottom: 1px solid var(--border); font-size: 14px; }
        tr:last-child td { border-bottom: none; }
        .cell-num { font-family: var(--font-mono); text-align: right; }
        th.cell-num { text-align: right; }
        
        .tag { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
        .badge { padding: 4px 8px; border-radius: 4px; font-family: var(--font-mono); font-size: 12px; font-weight: 600; }
        .badge.pos { color: var(--green); background: rgba(48, 209, 88, 0.1); }
        .badge.neg { color: var(--red); background: rgba(255, 69, 58, 0.1); }
        .badge.neu { color: var(--gray); background: rgba(142, 142, 147, 0.1); }

        @media (max-width: 1024px) { .viz-grid { grid-template-columns: 1fr 1fr; } .viz-grid .viz-card:last-child { grid-column: span 2; } }
        @media (max-width: 768px) { .viz-grid { grid-template-columns: 1fr; } .viz-grid .viz-card:last-child { grid-column: span 1; } .header { flex-direction: column; align-items: flex-start; gap: 16px; } }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div class="title-block">
            <h1>Panorama Patrimonial</h1>
            <p id="status-text">OBTENIENDO DATOS...</p>
        </div>
        <div class="nav-tools">
            <a href="cartera.html" class="nav-btn">Equilibrio Cartera</a>
            <a href="calculadora-3.html" class="nav-btn">Calculadora Trading</a>
            <a href="hoja-de-ruta.html" class="nav-btn">Hoja de Ruta</a>
        </div>
    </div>

    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-lbl">Patrimonio Total</div>
            <div class="kpi-val" id="kpi-total">--</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-lbl">Capital Invertido (Motor)</div>
            <div class="kpi-val" id="kpi-inv">--</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-lbl">Fondo de Maniobra (Liquidez)</div>
            <div class="kpi-val" id="kpi-liq">--</div>
        </div>
    </div>

    <div class="viz-grid">
        <div class="viz-card">
            <h3>Distribución de Inversión</h3>
            <div class="canvas-container"><canvas id="donutChart"></canvas></div>
        </div>
        
        <div class="viz-card">
            <h3>Rendimiento del Mercado</h3>
            <div class="canvas-container"><canvas id="barChart"></canvas></div>
        </div>

        <div class="viz-card">
            <h3>Crecimiento Patrimonial (Capital Total)</h3>
            <div class="canvas-container"><canvas id="lineChart"></canvas></div>
        </div>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Estrategia</th>
                    <th>Concepto</th>
                    <th class="cell-num">Capital Acumulado</th>
                    <th class="cell-num">Peso Cartera</th>
                    <th class="cell-num">Objetivo</th>
                    <th class="cell-num">Rendimiento Mercado</th>
                </tr>
            </thead>
            <tbody id="table-body">
                </tbody>
        </table>
    </div>
</div>

